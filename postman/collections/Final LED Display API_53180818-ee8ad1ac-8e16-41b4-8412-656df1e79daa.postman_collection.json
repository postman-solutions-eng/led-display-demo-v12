    {
      "name": "predefined-icons",
      "item": [
        {
          "name": "Get Predefined Icons",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is below 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "pm.test(\"Content-Type header is application/json\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});",
                  "",
                  "pm.test(\"Response body is an object (not an array)\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an(\"object\").and.not.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Response body has an 'icons' property\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"icons\");",
                  "});",
                  "",
                  "pm.test(\"'icons' is an array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.icons).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"'icons' array is not empty\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.icons).to.have.length.above(0);",
                  "});",
                  "",
                  "pm.test(\"Every item in 'icons' is a string\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    jsonData.icons.forEach(function (icon) {",
                  "        pm.expect(icon).to.be.a(\"string\");",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Every item in 'icons' matches shortcode format (starts and ends with a colon)\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var shortcodePattern = /^:[^:]+:$/;",
                  "    jsonData.icons.forEach(function (icon) {",
                  "        pm.expect(icon).to.match(shortcodePattern);",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"'icons' array contains at least 10 items\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.icons.length).to.be.at.least(10);",
                  "});",
                  "",
                  "pm.test(\"No duplicate icons exist in the array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var uniqueIcons = new Set(jsonData.icons);",
                  "    pm.expect(uniqueIcons.size).to.equal(jsonData.icons.length);",
                  "});",
                  "",
                  "pm.test(\"Response body has no unexpected top-level keys (only 'icons')\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var allowedKeys = [\"icons\"];",
                  "    var actualKeys = Object.keys(jsonData);",
                  "    actualKeys.forEach(function (key) {",
                  "        pm.expect(allowedKeys).to.include(key);",
                  "    });",
                  "});",
                  ""
                ]
              }
            }
          ],
